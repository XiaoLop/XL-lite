<%
// 收集需要的 class-validator 装饰器
const neededDecorators = new Set();
neededDecorators.add('IsOptional'); // 查询字段全部可选

if (fields) {
    fields.forEach(field => {
        const type = (field.type || '').toLowerCase();
        if (type.endsWith('[]')) {
            neededDecorators.add('IsArray');
            const itemType = type.replace('[]', '');
            if (itemType === 'number') neededDecorators.add('IsNumber');
            else if (itemType === 'boolean') neededDecorators.add('IsBoolean');
            else if (itemType === 'date') neededDecorators.add('IsDate');
            else neededDecorators.add('IsString');
        } else if (type === 'number') {
            neededDecorators.add('IsNumber');
        } else if (type === 'boolean') {
            neededDecorators.add('IsBoolean');
        } else if (type === 'date') {
            neededDecorators.add('IsDate');
        } else {
            neededDecorators.add('IsString');
        }
    });
}

const imports = Array.from(neededDecorators).sort();
%>
import { ApiProperty, IntersectionType, PartialType } from '@nestjs/swagger';
<% if (imports.length > 0) { %>
import { <%- imports.join(', ') %> } from 'class-validator';
<% } %>
import { PaginationDto } from 'common/dto/pagination.dto';
import { EmptyToUndefined } from 'common/decorators/empty-to-undefined.decorator';
import { Type } from 'class-transformer';

// 查询参数
export class <%- queryDtoName %> {
    @ApiProperty({ description: 'id', required: false })
    @EmptyToUndefined()
    @IsOptional()
    @Type(() => Number)
    @IsNumber()
    id?: number;

<% if (fields && fields.length > 0) {
    fields.forEach(field => {
        const rawType = (field.type || '').toLowerCase();
        const isArray = rawType.endsWith('[]');
        const itemType = isArray ? rawType.replace('[]', '') : rawType;
        const tsType = isArray
            ? (itemType === 'number' ? 'number' : itemType === 'boolean' ? 'boolean' : itemType === 'date' ? 'Date' : 'string') + '[]'
            : (itemType === 'number' ? 'number' : itemType === 'boolean' ? 'boolean' : itemType === 'date' ? 'Date' : 'string');
_%>

    @ApiProperty({ description: '<%- field.comment || field.name %>', required: false })
    @EmptyToUndefined()
    @IsOptional()
<% if (isArray) { -%>
    @IsArray()
<%   if (itemType === 'number') { -%>
    @IsNumber({}, { each: true })
<%   } else if (itemType === 'boolean') { -%>
    @IsBoolean({ each: true })
<%   } else if (itemType === 'date') { -%>
    @IsDate({ each: true })
<%   } else { -%>
    @IsString({ each: true })
<%   } -%>
<% } else if (itemType === 'number') { -%>
    @Type(() => Number)
    @IsNumber()
<% } else if (itemType === 'boolean') { -%>
    @IsBoolean()
<% } else if (itemType === 'date') { -%>
    @IsDate()
<% } else { -%>
    @IsString()
<% } -%>
    <%- field.name %>?: <%- tsType %>;
<% });
} %>

    @ApiProperty({ description: '创建时间', required: false })
    @EmptyToUndefined()
    @IsOptional()
    @IsString()
    createdAt?: string;

    @ApiProperty({ description: '更新时间', required: false })
    @EmptyToUndefined()
    @IsOptional()
    @IsString()
    updatedAt?: string;
}

// 分页参数
export class <%- paginationDtoName %> extends IntersectionType(
    PartialType(PaginationDto),
    <%- queryDtoName %>,
) {}

// 响应参数
export class <%- responseDtoName %> {
    @ApiProperty({ description: '总条' })
    total!: number;

    @ApiProperty({ description: '列表', type: <%- queryDtoName %>, isArray: true })
    list!: <%- queryDtoName %>[];
}
