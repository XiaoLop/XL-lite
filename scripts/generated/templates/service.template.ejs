import { Injectable } from '@nestjs/common';
import { InjectRepository } from '@nestjs/typeorm';
import { Repository } from 'typeorm';
import { buildWhere, PAGINATION_FIELDS } from 'common/utils/pagination.util';
import { <%- entityName %> } from './entities/<%- globalName %>.entity';
import { <%- createDtoName %> } from './dto/create.dto';
import { <%- updateDtoName %> } from './dto/update.dto';
import { <%- paginationDtoName %> } from './dto/query.dto';

@Injectable()
export class <%- serviceName %> {
    constructor(
        @InjectRepository(<%- entityName %>) private readonly repo: Repository<<%- entityName %>>,
    ) {}
    async create(body: <%- createDtoName %>) {
        await this.repo.save(body);
    }

    async findAll(query: <%- paginationDtoName %>) {
        const { pageNum = 1, pageSize = 10 } = query;
        const where = buildWhere(query, PAGINATION_FIELDS);
        const [list, total] = await this.repo.findAndCount({
            where,
            skip: (pageNum - 1) * pageSize,
            take: pageSize,
            order: { id: 'DESC' },
        });
        return { list, total };
    }

    findOne(id: number) {
        return this.repo.findOneBy({ id });
    }

    update(id: number, body: <%- updateDtoName %>) {
        return this.repo.update(id, body);
    }

    remove(ids: number[]) {
        if (!ids.length) return { affected: 0 };
        return this.repo.delete(ids);
    }
}
