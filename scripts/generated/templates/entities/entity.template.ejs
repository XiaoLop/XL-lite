
import {
    Column,
    Entity,
    PrimaryGeneratedColumn,
    CreateDateColumn,
    UpdateDateColumn,
} from 'typeorm';

@Entity()
export class <%= entityName %> {
    @PrimaryGeneratedColumn()
    id!: number;

<% if (typeof fields !== 'undefined' && fields) { 
fields.forEach(function(field) {
    var options = [];
    
    if (!field.required) {
        options.push('nullable: true');
    }
    
    if (field.default && field.default.trim() !== '') {
        var defaultVal = field.default.trim();
        if (!/^-?\d+(\.\d+)?$/.test(defaultVal) && defaultVal !== 'true' && defaultVal !== 'false' && defaultVal !== 'null') {
            defaultVal = "'" + defaultVal.replace(/'/g, "\\'") + "'";
        }
        options.push('default: ' + defaultVal);
    }
    
    if (field.comment && field.comment.trim() !== '') {
        options.push("comment: '" + field.comment.replace(/'/g, "\\'") + "'");
    }
    
    var decorator = '@Column';
    if (options.length > 0) {
        decorator += '({\n        ' + options.join(',\n        ') + '\n    })';
    } else {
        decorator += '()';
    }
    
    var optionalMark = field.required ? '!' : '?';
    var tsComment = field.comment ? ' // ' + field.comment : '';
%>

    <%- decorator %>
    <%- field.name %><%- optionalMark %>: <%- field.type %><%- tsComment %>
<% }); 
} %>
    @CreateDateColumn()
    createdAt!: Date;

    @UpdateDateColumn()
    updatedAt!: Date;
}
